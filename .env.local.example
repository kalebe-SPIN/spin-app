# =================================================================
# Variáveis de ambiente — spin-app
# Copia este arquivo pra .env.local e preenche com seus valores REAIS.
# NUNCA commita .env.local (já está no .gitignore).
# =================================================================

# ===== Supabase =====
# Pegue em: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# Service role NUNCA vai no client. Só pra rotas server/admin.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJI...

# ===== App =====
# URL base do app (em dev: http://localhost:3000 / em prod: https://app.spinsolar.com.br)
NEXT_PUBLIC_APP_URL=http://localhost:3000
